# ── Supabase ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Sentry error monitoring ───────────────────────────────────────────────────
# Kreirati projekt na https://sentry.io, pa kopirati DSN iz Settings > Client Keys
EXPO_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# ── Sentry source map upload (CI/CD only — ne commitovati) ───────────────────
# SENTRY_ORG=aquapulse
# SENTRY_PROJECT=myaquapulse-rn
# SENTRY_AUTH_TOKEN=sntrys_...

# ── Lokalni razvoj ────────────────────────────────────────────────────────────
EXPO_PUBLIC_RORK_API_BASE_URL=http://192.168.x.x:3000
